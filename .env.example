# Dark Angel - Environment Variables

# Node Environment
NODE_ENV=development

# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
PREFIX=!
OWNER_ID=your_discord_id

# Database (MongoDB)
MONGO_URI=mongodb://localhost:27017/dark-angel
# Or use MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dark-angel

# Web Server
PORT=3000
HOST=localhost

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Logging
LOG_LEVEL=info

# Panel Configuration
PANEL_URL=https://your-panel-url.com
PANEL_API_KEY=your_panel_api_key

# Features
ENABLE_DISCORD_BOT=true
ENABLE_WEB_PANEL=true
ENABLE_API=true
